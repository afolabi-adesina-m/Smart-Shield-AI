    "import requests\n",
    "\n",
    "def get_live_weather(lat, lon):\n",
    "    \"\"\"\n",
    "    Pulls live environmental data from Open-Meteo for specific coordinates.\n",
    "    \"\"\"\n",
    "    print(f\"\\n🌤️ Fetching weather for Coordinates: {lat}, {lon}...\")\n",
    "    \n",
    "    # We are requesting current temperature, precipitation (rain/snow), and a standardized weather code\n",
    "    url = f\"https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current=temperature_2m,precipitation,weather_code\"\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(url)\n",
    "        response.raise_for_status()\n",
    "        data = response.json()\n",
    "        \n",
    "        current = data.get('current', {})\n",
    "        \n",
    "        print(\"--- Environmental Data ---\")\n",
    "        print(f\"Temperature:   {current.get('temperature_2m')} °C\")\n",
    "        print(f\"Precipitation: {current.get('precipitation')} mm\")\n",
    "        print(f\"Weather Code:  {current.get('weather_code')} (Standardized WMO code)\")\n",
    "        \n",
    "        return current\n",
    "        \n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"Error fetching weather data: {e}\")\n",
    "        return None\n"
