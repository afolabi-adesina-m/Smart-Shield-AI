    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "def profile_dataframe(df, name=\"Dataset\"):\n",
    "    \"\"\"Prints structural and missing value analysis for a given DataFrame.\"\"\"\n",
    "    print(f\"\\n=========================================\")\n",
    "    print(f\" {name.upper()} STRUCTURAL PROFILE\")\n",
    "    print(f\"=========================================\")\n",
    "    print(f\"Total Logged Records : {df.shape[0]:,}\")\n",
    "    print(f\"Total Column Metrics : {df.shape[1]}\")\n",
    "\n",
    "    print(f\"\\n=========================================\")\n",
    "    print(f\" {name.upper()} MISSING VALUE METRIC ANALYSIS\")\n",
    "    print(f\"=========================================\")\n",
    "    missing_matrix = pd.DataFrame({\n",
    "        'Data Type': df.dtypes,\n",
    "        'Null Records': df.isnull().sum(),\n",
    "        'Null Percentage': (df.isnull().sum() / len(df)) * 100\n",
    "    }).sort_values(by='Null Percentage', ascending=False)\n",
    "    print(missing_matrix)\n",
    "\n",
    "\n",
    "# --- Toronto Police Data (from .xlsx) ---\n",
    "try:\n",
    "    df_toronto = pd.read_excel('traffic_collision_data.xlsx')\n",
    "    print(\"Loaded 'traffic_collision_data.xlsx' for Toronto Police data.\")\n",
    "    profile_dataframe(df_toronto, \"Toronto Police Data\")\n",
    "\n",
    "    # Target Class Balance Profiling for Toronto\n",
    "    print(\"\\n=========================================\")\n",
    "    print(\" TORONTO POLICE TARGET CLASS SEVERITY BALANCE (ACCLASS)\")\n",
    "    print(\"=========================================\")\n",
    "    distribution_percentage = df_toronto['ACCLASS'].value_counts(normalize=True) * 100\n",
    "    distribution_raw = df_toronto['ACCLASS'].value_counts()\n",
    "    for idx in distribution_percentage.index:\n",
    "        print(f\"Class [{idx:15}]: {distribution_raw[idx]:5} entries ({distribution_percentage[idx]:.2f}%)\")\n",
    "\n",
    "    # Feature Space Category Density for Toronto\n",
    "    print(\"\\n=========================================\")\n",
    "    print(\" TORONTO POLICE SURFACE HAZARD & ENVIRONMENTAL FREQUENCIES\")\n",
    "    print(\"=========================================\")\n",
    "    print(\"\\n[Top Visibility Vectors]\")\n",
    "    print(df_toronto['VISIBILITY'].value_counts().head(3))\n",
    "    print(\"\\n[Top Road Surface States]\")\n",
    "    print(df_toronto['RDSFCOND'].value_counts().head(3))\n",
    "\n",
    "except FileNotFoundError:\n",
    "    print(\"⚠️ 'traffic_collision_data.xlsx' not found. Skipping Toronto Police data profiling.\")\n",
    "\n",
    "# --- Seattle Department of Transportation Data (Simulated based on PDF info) ---\n",
    "print(\"\\n\"*2 + \"--- Simulating Seattle Department of Transportation Data ---\")\n",
    "records_seattle = 300000 # Example number based on 772,553 total for combined datasets in PDF\n",
    "df_seattle = pd.DataFrame({\n",
    "    'INCDATE': pd.to_datetime(pd.date_range(start='2010-01-01', periods=records_seattle, freq='H')),\n",
    "    'INCTIME': pd.to_datetime(pd.date_range(start='2010-01-01', periods=records_seattle, freq='H')).time,\n",
    "    'SEVERITYCODE': np.random.choice([1, 2, 3], p=[0.70, 0.25, 0.05], size=records_seattle), # 1-slight, 2-serious, 3-fatal\n",
    "    'ROADCOND': np.random.choice(['Dry', 'Wet', 'Snow', 'Ice', 'Standing Water', 'Other'], p=[0.6, 0.2, 0.08, 0.05, 0.05, 0.02], size=records_seattle),\n",
    "    'LIGHTCOND': np.random.choice(['Daylight', 'Darkness/Lights Lit', 'Dusk', 'Dawn', 'Darkness/Lights Unlit', 'Other'], p=[0.5, 0.2, 0.1, 0.05, 0.1, 0.05], size=records_seattle),\n",
    "    'WEATHER': np.random.choice(['Clear', 'Raining', 'Snowing', 'Fog or Mist', 'High Wind', 'Other'], p=[0.65, 0.2, 0.05, 0.03, 0.02, 0.05], size=records_seattle),\n",
    "    'JUNCTIONTYPE': np.random.choice(['At Intersection', 'Mid-Block', 'Driveway Junction', 'Ramp Junction', 'Other'], p=[0.4, 0.3, 0.15, 0.1, 0.05], size=records_seattle),\n",
    "    'LATITUDE': np.random.uniform(47.4, 47.8, size=records_seattle),\n",
    "    'LONGITUDE': np.random.uniform(-122.5, -122.1, size=records_seattle)\n",
    "})\n",
    "profile_dataframe(df_seattle, \"Seattle SDOT Data\")\n",
    "\n",
    "print(\"\\n=========================================\")\n",
    "print(\" SEATTLE SDOT TARGET CLASS SEVERITY BALANCE (SEVERITYCODE)\")\n",
    "print(\"=========================================\")\n",
    "distribution_percentage = df_seattle['SEVERITYCODE'].value_counts(normalize=True) * 100\n",
    "distribution_raw = df_seattle['SEVERITYCODE'].value_counts()\n",
    "for idx in distribution_percentage.index:\n",
    "    print(f\"Class [{idx:15}]: {distribution_raw[idx]:5} entries ({distribution_percentage[idx]:.2f}%)\")\n",
    "\n",
    "# --- UK Department for Transport Data (Simulated based on PDF info) ---\n",
    "print(\"\\n\"*2 + \"--- Simulating UK Department for Transport Data ---\")\n",
    "records_uk = 472553 # Example number based on 772,553 total for combined datasets in PDF\n",
    "df_uk = pd.DataFrame({\n",
    "    'date': pd.to_datetime(pd.date_range(start='2015-01-01', periods=records_uk, freq='D')),\n",
    "    'time': pd.to_datetime(pd.date_range(start='2015-01-01', periods=records_uk, freq='H')).time,\n",
    "    'accident_severity': np.random.choice([1, 2, 3], p=[0.70, 0.25, 0.05], size=records_uk), # 1-slight, 2-serious, 3-fatal\n",
    "    'road_surface_conditions': np.random.choice(['Dry', 'Wet', 'Snow', 'Ice or frost', 'Standing water', 'Oil or diesel', 'Mud', 'Other'], p=[0.6, 0.2, 0.08, 0.05, 0.02, 0.01, 0.01, 0.03], size=records_uk),\n",
    "    'light_conditions': np.random.choice(['Daylight', 'Darkness/lights lit', 'Dusk', 'Dawn', 'Darkness/lights unlit', 'Darkness/no lighting', 'Other'], p=[0.5, 0.2, 0.1, 0.05, 0.1, 0.02, 0.03], size=records_uk),\n",
    "    'weather_conditions': np.random.choice(['Clear', 'Raining', 'Snowing', 'Fog or mist', 'High wind', 'Blowing sand/dirt', 'Unknown', 'Other'], p=[0.65, 0.2, 0.05, 0.03, 0.01, 0.01, 0.02, 0.03], size=records_uk),\n",
    "    'junction_detail': np.random.choice(['At intersection', 'Mid-block', 'Driveway junction', 'Ramp junction', 'Other'], p=[0.4, 0.3, 0.15, 0.1, 0.05], size=records_uk),\n",
    "    'LATITUDE': np.random.uniform(50.0, 58.0, size=records_uk),\n",
    "    'LONGITUDE': np.random.uniform(-7.0, 2.0, size=records_uk)\n",
    "})\n",
    "profile_dataframe(df_uk, \"UK DfT Data\")\n",
    "\n",
    "print(\"\\n=========================================\")\n",
    "print(\" UK DfT TARGET CLASS SEVERITY BALANCE (ACCIDENT_SEVERITY)\")\n",
    "print(\"=========================================\")\n",
    "distribution_percentage = df_uk['accident_severity'].value_counts(normalize=True) * 100\n",
    "distribution_raw = df_uk['accident_severity'].value_counts()\n",
    "for idx in distribution_percentage.index:\n",
    "    print(f\"Class [{idx:15}]: {distribution_raw[idx]:5} entries ({distribution_percentage[idx]:.2f}%)\")\n"
