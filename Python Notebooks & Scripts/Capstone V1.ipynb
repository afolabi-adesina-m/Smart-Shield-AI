    "# Smart-Shield AI: Data Ingestion & Preprocessing Pipeline (WP1)\n",
    "This notebook initializes the data gathering layer for the Capstone project. It implements:\n",
    "1. Automated weather feature extraction from Open-Meteo.\n",
    "2. Unstructured NLP alert extraction from Ontario 511.\n",
    "3. Categorical road surface condition streaming for target labeling.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": None,
   "id": "4876b27a",
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import time\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "def get_live_weather(lat, lon):\n",
    "    \"\"\"Block 1: Open-Meteo Environmental Ingestion\"\"\"\n",
    "    print(f\"🌤️ Fetching weather for Coordinates: {lat}, {lon}...\")\n",
    "    url = f\"https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current=temperature_2m,precipitation,weather_code\"\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(url)\n",
    "        response.raise_for_status()\n",
    "        current = response.json().get('current', {})\n",
    "        print(\"Success: Environmental data fetched.\")\n",
    "        return current\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"Error fetching weather data: {e}\")\n",
    "        return None\n",
    "\n",
    "def get_ontario_511_events():\n",
    "    \"\"\"Block 2: Ontario 511 Hazard Alerts (NLP Raw Stream)\"\"\"\n",
    "    print(\"📋 Fetching live road alerts from Ontario 511...\")\n",
    "    url = \"https://511on.ca/api/v2/get/event\"\n",
    "    headers = {'Accept': 'application/json', 'User-Agent': 'Smart-Shield-AI-Pipeline/1.0'}\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(url, headers=headers)\n",
    "        response.raise_for_status()\n",
    "        events_data = response.json()\n",
    "        print(f\"Success: Pulled {len(events_data)} active text alerts.\")\n",
    "        return events_data\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"Error fetching 511 text events: {e}\")\n",
    "        return None\n",
    "\n",
    "def get_ontario_road_conditions():\n",
    "    \"\"\"Block 3: Ontario 511 Surface Labels (Ground Truth Engine)\"\"\"\n",
    "    print(\"🛣️ Fetching live road conditions from Ontario 511...\")\n",
    "    url = \"https://511on.ca/api/v2/get/roadconditions\"\n",
    "    headers = {'Accept': 'application/json', 'User-Agent': 'Smart-Shield-AI-Pipeline/1.0'}\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(url, headers=headers)\n",
    "        response.raise_for_status()\n",
    "        conditions_data = response.json()\n",
    "        print(f\"Success: Pulled {len(conditions_data)} active surface reports.\")\n",
    "        return conditions_data\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"Error fetching road conditions: {e}\")\n",
    "        return None\n"
   ]
  },
  {
