    ["Smart-Shield", "The Ontario highway safety AI system that fuses text alerts, road images, and collision data to produce a composite Safety Score and speed recommendation."],
    ["3-Brain Architecture", "Three pillars: NLP Brain (text), Vision Brain (images), Logistic Optimizer (tabular ML), fused into one Safety Score."],
    ["NLP Brain (Pillar 1)", "Scores Ontario 511-style alerts using TF-IDF and a hazard lexicon. Output: T score (0-1)."],
    ["Vision Brain (Pillar 2)", "ResNet18 CNN fine-tuned on road-surface images. Output: V score (vision hazard probability)."],
    ["Logistic Optimizer (Pillar 3)", "Tabular classifiers predicting collision severity from structured features."],
    ["Safety Score (S)", "Composite score 0-100: S = (w_T*T + w_V*V + w_E*E) x 100. Higher S = higher risk."],
    ["T Score", "Text hazard score from TF-IDF on weather/traffic alerts."],
    ["V Score", "Vision hazard probability for wet/snow/ice road conditions."],
    ["E_index", "Environmental risk from weather, surface, season, time-of-day (calibrated on UK DfT data)."],
    ["TF-IDF", "Term Frequency-Inverse Document Frequency for NLP alert scoring."],
    ["SEVERITY", "3-class target: 0=PD only, 1=Injury, 2=Fatal."],
    ["df_toronto", "Toronto Police Service collision DataFrame."],
    ["dft", "UK DfT 2024 collision DataFrame for E_index calibration."],
    ["df_model", "Preprocessed 8-feature matrix + SEVERITY for ML."],
